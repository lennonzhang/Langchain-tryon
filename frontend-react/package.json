{
  "name": "langchain-tryon-frontend",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "type": "module",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test --project=e2e-desktop tests/e2e",
    "test:visual": "playwright test --project=visual-desktop --project=visual-mobile tests/visual",
    "test:all": "pnpm test && pnpm test:visual && pnpm test:e2e"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.5",
    "dompurify": "^3.2.6",
    "marked": "^12.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^26.1.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
