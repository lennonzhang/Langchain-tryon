{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "corepack enable && corepack prepare pnpm@10.0.0 --activate && cd frontend-react && pnpm install --frozen-lockfile",
  "buildCommand": "corepack enable && corepack prepare pnpm@10.0.0 --activate && cd frontend-react && pnpm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/chat",
      "destination": "/api/chat.py"
    },
    {
      "source": "/api/chat/stream",
      "destination": "/api/chat/stream.py"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/frontend/dist/assets/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/dist/index.html"
    }
  ],
  "functions": {
    "api/chat.py": {
      "maxDuration": 60
    },
    "api/chat/stream.py": {
      "maxDuration": 300
    }
  }
}
