{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/static/(.*)",
      "destination": "/frontend/static/$1"
    }
  ],
  "functions": {
    "api/chat.py": {
      "maxDuration": 60
    },
    "api/chat/stream.py": {
      "maxDuration": 300
    }
  }
}
