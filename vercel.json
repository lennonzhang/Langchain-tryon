{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd frontend-react && npx -y pnpm@10.0.0 install --frozen-lockfile",
  "buildCommand": "cd frontend-react && npx -y pnpm@10.0.0 run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/capabilities",
      "destination": "/api/capabilities.py"
    },
    {
      "source": "/api/chat",
      "destination": "/api/chat.py"
    },
    {
      "source": "/api/chat/stream",
      "destination": "/api/chat/stream.py"
    },
    {
      "source": "/api/chat/cancel",
      "destination": "/api/chat/cancel.py"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/frontend/dist/assets/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/dist/index.html"
    }
  ],
  "functions": {
    "api/chat.py": {
      "maxDuration": 60,
      "excludeFiles": "{tests/**,docs/**,legacy/**,frontend-react/**,.claude/**,.cursor/**,.vscode/**,.github/**,tmp*/**,__pycache__/**,.pytest_cache/**,README.md,CHANGELOG.md,AGENTS.md,CLAUDE.md,api_examples.py,opencode.json}"
    },
    "api/chat/stream.py": {
      "maxDuration": 300,
      "excludeFiles": "{tests/**,docs/**,legacy/**,frontend-react/**,.claude/**,.cursor/**,.vscode/**,.github/**,tmp*/**,__pycache__/**,.pytest_cache/**,README.md,CHANGELOG.md,AGENTS.md,CLAUDE.md,api_examples.py,opencode.json}"
    },
    "api/chat/cancel.py": {
      "maxDuration": 60,
      "excludeFiles": "{tests/**,docs/**,legacy/**,frontend-react/**,.claude/**,.cursor/**,.vscode/**,.github/**,tmp*/**,__pycache__/**,.pytest_cache/**,README.md,CHANGELOG.md,AGENTS.md,CLAUDE.md,api_examples.py,opencode.json}"
    },
    "api/capabilities.py": {
      "excludeFiles": "{tests/**,docs/**,legacy/**,frontend-react/**,.claude/**,.cursor/**,.vscode/**,.github/**,tmp*/**,__pycache__/**,.pytest_cache/**,README.md,CHANGELOG.md,AGENTS.md,CLAUDE.md,api_examples.py,opencode.json}"
    }
  }
}
